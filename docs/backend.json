{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "description": "The user's role.",
          "enum": [
            "mayor",
            "staff"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the user was created."
        }
      },
      "required": [
        "name",
        "email",
        "role",
        "createdAt"
      ]
    },
    "HouseHolder": {
      "title": "House Holder",
      "description": "Represents a house holder in Arba-Minch city.",
      "type": "object",
      "properties": {
        "houseNumber": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "familySize": {
          "type": "number"
        },
        "kebele": {
          "type": "string"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "houseNumber",
        "fullName",
        "phone",
        "familySize",
        "kebele",
        "latitude",
        "longitude",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "email",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information, keyed by user ID."
    },
    "/householders/{householderId}": {
      "schema": {
        "$ref": "#/entities/HouseHolder"
      },
      "description": "Stores house holder information."
    }
  }
}
